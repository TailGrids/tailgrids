{
  "name": "@tailgrids/mcp",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "An MCP (Model Context Protocol) server that exposes the Tailgrids UI components to AI agents",
  "bin": {
    "tailgrids-mcp": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/main.js",
    "start": "npx @modelcontextprotocol/inspector node dist/main.js",
    "generate-registry": "tsx scripts/generate-registry.ts"
  },
  "keywords": [
    "@tailgrids/mcp",
    "tailgrids",
    "mcp",
    "tailwind",
    "ui",
    "components",
    "ai",
    "agent",
    "mcp-server"
  ],
  "author": {
    "name": "Tailgrids",
    "url": "https://tailgrids.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tailgrids/tailgrids.git",
    "directory": "/packages/mcp"
  },
  "homepage": "https://tailgrids.com",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "glob": "^13.0.6",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
